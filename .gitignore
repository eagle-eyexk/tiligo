# ============================================
# CAPACITOR iOS - DO NOT IGNORE THESE
# ============================================
# The Podfile is REQUIRED for building
# Do not ignore: ios/App/Podfile

# ============================================
# CAPACITOR iOS - DO NOT IGNORE THESE
# ============================================
# The Podfile is REQUIRED for building
# Do not ignore: ios/App/Podfile

# ============================================
# CAPACITOR iOS - CRITICAL FILES
# ============================================
# These MUST be committed for CI/CD

# Keep Podfile
!ios/App/Podfile

# Keep Xcode project
!ios/App/App.xcodeproj/
!ios/App/App.xcworkspace/

# Keep app source files
!ios/App/App/*.swift
!ios/App/App/*.plist
!ios/App/App/*.entitlements
!ios/App/App/Assets.xcassets/

# Keep Capacitor config in App
!ios/App/App/capacitor.config.json

# But ignore these generated files
ios/App/Pods/
ios/App/build/
ios/App/*.xcworkspace/xcuserdata/
ios/App/*.xcodeproj/xcuserdata/
